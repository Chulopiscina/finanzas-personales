generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum ImportStatus {
  COMPLETED
  FAILED
  PENDING
}

enum AccountType {
  BANK
  SAVINGS
  CARD
  CASH
  INVESTMENT
  DEBT
  OTHER
}

enum CategoryType {
  INCOME
  EXPENSE
  SAVINGS
  TRANSFER
  OTHER
}

enum PlanningGoalType {
  FIXED_EXPENSE
  VARIABLE_EXPENSE
  SAVINGS
  INVESTMENT
  DEBT
  OTHER
}

enum PlanningPeriod {
  MONTHLY
  ANNUAL
  CUSTOM
}

enum PlanningStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  passwordHash     String
  role             Role             @default(USER)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  lastLoginAt      DateTime?
  transactions     Transaction[]
  monthlySummaries MonthlySummary[]
  imports          ImportHistory[]
  sessions         Session[]
  accounts         Account[]
  categories       Category[]
  planningGoals    PlanningGoal[]

  @@index([role])
  @@index([lastLoginAt])
}

model Account {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  type          AccountType     @default(BANK)
  initialBalance Decimal        @default(0) @db.Decimal(12, 2)
  currency      String          @default("EUR")
  color         String?
  icon          String?
  isArchived    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  transactions  Transaction[]
  imports       ImportHistory[]
  planningGoals PlanningGoal[]

  @@unique([userId, name])
  @@index([userId, isArchived])
}

model Category {
  id           String        @id @default(cuid())
  userId       String?
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         CategoryType  @default(OTHER)
  color        String
  icon         String
  isArchived   Boolean       @default(false)
  transactions Transaction[]
  planningGoals PlanningGoalCategory[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([userId, name])
  @@index([userId, isArchived])
  @@index([name])
}

model Transaction {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId       String
  account         Account         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  categoryId      String?
  category        Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  importHistoryId String?
  importHistory   ImportHistory?  @relation(fields: [importHistoryId], references: [id], onDelete: SetNull)
  date            DateTime
  concept         String
  cleanDescription String?
  rawDescription  String?
  amount          Decimal         @db.Decimal(12, 2)
  balance         Decimal?        @db.Decimal(12, 2)
  type            TransactionType
  isInternalTransfer Boolean      @default(false)
  internalTransferGroupId String?
  internalTransferCounterAccountId String?
  planningGoals   PlanningGoalTransaction[]
  sourceHash      String
  raw             Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([userId, accountId, sourceHash])
  @@index([userId, date])
  @@index([accountId, date])
  @@index([categoryId])
  @@index([importHistoryId])
  @@index([type])
  @@index([isInternalTransfer])
  @@index([internalTransferGroupId])
}

model PlanningGoal {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String?
  account      Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)
  name         String
  type         PlanningGoalType
  targetAmount Decimal             @db.Decimal(12, 2)
  period       PlanningPeriod      @default(MONTHLY)
  periodStart  DateTime?
  periodEnd    DateTime?
  color        String?
  icon         String?
  status       PlanningStatus      @default(ACTIVE)
  showInDashboard Boolean          @default(false)
  categories   PlanningGoalCategory[]
  transactions PlanningGoalTransaction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([userId, status])
  @@index([userId, showInDashboard])
  @@index([accountId])
}

model PlanningGoalCategory {
  goalId     String
  categoryId String
  goal       PlanningGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  category   Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([goalId, categoryId])
  @@index([categoryId])
}

model PlanningGoalTransaction {
  goalId                  String
  transactionId           String
  includeInternalTransfer Boolean     @default(false)
  createdAt               DateTime    @default(now())
  goal                    PlanningGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  transaction             Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@id([goalId, transactionId])
  @@index([transactionId])
}

model MonthlySummary {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month             DateTime
  income            Decimal  @db.Decimal(12, 2)
  expenses          Decimal  @db.Decimal(12, 2)
  savings           Decimal  @db.Decimal(12, 2)
  transactionCount  Int
  topCategory       String?
  categoryBreakdown Json
  insights          Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId, month])
}

model ImportHistory {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  fileName      String
  fileHash      String
  fileSize      Int          @default(0)
  mimeType      String?
  fileContent   String?      @db.Text
  rowCount      Int
  insertedRows  Int
  duplicateRows Int
  incomeTotal   Decimal      @default(0) @db.Decimal(12, 2)
  expenseTotal  Decimal      @default(0) @db.Decimal(12, 2)
  status        ImportStatus
  errorMessage  String?
  createdAt     DateTime     @default(now())
  transactions  Transaction[]

  @@index([userId, createdAt])
  @@index([accountId, createdAt])
  @@index([fileHash])
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}